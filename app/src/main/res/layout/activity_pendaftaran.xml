<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"> <!-- Warna background putih bersih kebiruan -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo Atma Luhur -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:src="@drawable/logo_atmaluhur"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FORM PENDAFTARAN"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Card untuk Foto & Upload -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/img_pendaftaran"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_user_placeholder" />

                <Button
                    android:id="@+id/btn_upload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="UPLOAD FOTO"
                    android:backgroundTint="#0EA5E9" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Container Input Fields -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:orientation="vertical">

                <!-- Nama Lengkap -->
                <EditText
                    android:id="@+id/et_nama"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Nama Lengkap"
                    android:paddingStart="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:layout_marginBottom="12dp" />

                <!-- Tempat, Tanggal Lahir -->
                <EditText
                    android:id="@+id/et_ttl"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Tempat, Tanggal Lahir"
                    android:paddingStart="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:layout_marginBottom="12dp" />

                <!-- Nomor WhatsApp -->
                <EditText
                    android:id="@+id/et_wa"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Nomor WhatsApp"
                    android:inputType="phone"
                    android:paddingStart="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:layout_marginBottom="12dp" />

                <!-- Asal Sekolah -->
                <EditText
                    android:id="@+id/et_asal_sekolah"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Asal Sekolah"
                    android:paddingStart="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:layout_marginBottom="12dp" />

                <!-- Alamat Lengkap -->
                <EditText
                    android:id="@+id/et_alamat"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:hint="Alamat Lengkap"
                    android:gravity="top"
                    android:padding="16dp"
                    android:background="@drawable/bg_input_rounded" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Button Daftar -->
        <Button
            android:id="@+id/btn_daftar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SIMPAN PENDAFTARAN"
            android:textStyle="bold"
            android:backgroundTint="#1D4ED8"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>